{
  "name": "chox-cli",
  "version": "0.1.0",
  "description": "Local-only, cross-agent session substrate: lenses over your coding-agent history, ending in installable artifacts",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "chox": "dist/bin/chox.js"
  },
  "files": [
    "dist",
    "relays",
    "src/substrate/schema.sql",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-agents",
    "cli",
    "local-first",
    "cross-agent",
    "developer-tools",
    "workflow"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/chmod-bin.mjs",
    "verify:pack": "npm run build && node scripts/verify-pack.mjs",
    "dev": "tsc --watch",
    "fixtures:redact": "node --experimental-strip-types fixtures/redact.ts",
    "fixtures:verify": "node --experimental-strip-types fixtures/redact.ts --verify"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
